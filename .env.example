# ============================================================================
#  ÖRNEK ortam değişkenleri.
#  Bu dosyayı `.env` olarak KOPYALAYIN ve gerçek değerleri orada doldurun.
#  GERÇEK DEĞERLER / SECRET'LAR ASLA bu dosyaya yazılmaz ve commit edilmez.
#  Detaylar için SECURITY.md dosyasına bakın.
# ============================================================================

# ---- Genel ----
ENVIRONMENT=development            # development | staging | production
PROJECT_NAME=Social Media Agency Tool

# ---- Backend / API ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Frontend'in çağrı yapabilmesi için izin verilen origin'ler (virgülle ayrılır)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Veritabanı (PostgreSQL) ----
POSTGRES_USER=agency
POSTGRES_PASSWORD=change_me_in_local_env   # SADECE örnek; gerçeğini .env'e yazın
POSTGRES_DB=agency
POSTGRES_HOST=db
POSTGRES_PORT=5432
# SQLAlchemy bağlantı adresi (yukarıdakilerden türetilebilir)
DATABASE_URL=postgresql+psycopg://agency:change_me_in_local_env@db:5432/agency

# ---- Redis / Celery ----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ---- Auth / JWT ----
# Üretim için güçlü rastgele bir değer üretin:  openssl rand -hex 32
JWT_SECRET_KEY=generate_a_strong_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Frontend ----
VITE_API_BASE_URL=http://localhost:8000

# ---- Gelecek faz: gerçek platform entegrasyonları (ŞİMDİLİK BOŞ) ----
# META_API_KEY=
# META_API_SECRET=
# GOOGLE_ADS_DEVELOPER_TOKEN=
# X_API_KEY=
# X_API_SECRET=
